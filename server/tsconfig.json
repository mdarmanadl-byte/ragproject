{
  "compilerOptions": {
    "target": "ES2022",
    "module":"commonjs",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
   "typeRoots": ["./src/types", "./node_modules/@types"]
    
  
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}